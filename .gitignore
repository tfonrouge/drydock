# To validate, run:
#   'git ls-files -i --exclude-standard'

# build generated files
bin/*/
lib/*/
obj
.hbmk/
.zig-cache/
zig-out/
*.hbl
*.hbd
*.hbr
*.hrb

# 'install'-ed binaries
*.exe
*.dll
*.dxe
*.dylib
*.so
*.sl
*.lib
*.a

# packages
/pkg/

# not hosted contribs
/addons/

# misc junk
.DS_Store
*.bak

# Legacy Harbour-name symlinks (generated by bin/create-symlinks.sh)
# Real binaries use Drydock names; these are backward-compat aliases.
bin/*/harbour
bin/*/hbmk2
bin/*/hbtest
bin/*/hbrun
bin/*/hbpp
bin/*/hbi18n
bin/*/hbformat

# exceptions
!libunicows.a
!unicows.lib
!lib/3rd
!config/*.exe
!/*.exe
